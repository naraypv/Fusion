{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "module": "ESNext",
    "noEmit": true,
    "types": ["vitest/globals", "@testing-library/jest-dom", "node", "vite/client"],
    "paths": {
      "node-pty": ["./src/types/node-pty/index.d.ts"]
    }
  },
  "include": ["app/**/*"],
  "exclude": ["app/**/*.test.ts", "app/**/*.test.tsx", "app/**/__tests__/**/*"]
}
